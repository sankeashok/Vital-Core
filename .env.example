# =========================================================================
# Vital-Core Environment Configuration Skeleton
# =========================================================================

# 🚀 FastAPI Serving Mode (development / production)
APP_ENV=development

# 🤗 Hugging Face API Credentials (Required for Clinical Copilot translation)
HF_TOKEN=hf_your_token_here
HF_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct

# 📈 Remote MLflow Server (Optional: e.g. Dagshub integration)
# If these are left blank or omitted, it defaults to the local SQLite-backed 'mlflow.db'
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/YOUR_REPO_NAME.mlflow
MLFLOW_TRACKING_USERNAME=YOUR_USERNAME
MLFLOW_TRACKING_PASSWORD=YOUR_DAGSHUB_ACCESS_TOKEN
